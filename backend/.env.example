# Which odds provider to use: "theoddsapi" or "oddsapiio"
ODDS_PROVIDER=theoddsapi

# the-odds-api.com key (32-char hex). Get one at https://the-odds-api.com
ODDS_API_KEY_THEODDSAPI=your_theoddsapi_key_here

# odds-api.io / oddspapi.io key (UUID form)
ODDS_API_KEY_IO=your_oddsapiio_key_here

# Edge / staking config
MIN_EDGE=0.03          # only flag bets with >= 3% edge
KELLY_FRACTION=0.25    # quarter-Kelly
KELLY_CAP=0.05         # never stake more than 5% of bankroll on one bet
DEVIG_METHOD=shin      # "shin" (favorite-longshot corrected) or "proportional"
